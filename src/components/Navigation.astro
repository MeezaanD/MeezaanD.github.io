---
import ThemeToggle from "./ThemeToggle.astro";
import { site } from "../data/site";

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/"
    ? pathname === "/"
    : href.startsWith("mailto:")
      ? false
      : pathname.startsWith(href);
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-border bg-background/92 backdrop-blur-md"
>
  <nav class="mx-auto flex min-h-18 max-w-site items-center justify-between px-5 sm:px-8" aria-label="Primary navigation">
    <a href="/" class="font-mono text-sm font-medium tracking-[-0.02em] text-foreground">
      {site.domain}
    </a>

    <div class="hidden items-center gap-7 lg:flex">
      {
        site.navigation.map((item) => (
          <a
            href={item.href}
            class:list={[
              "border-b py-1 font-mono text-xs transition-colors",
              isActive(item.href)
                ? "border-primary text-foreground"
                : "border-transparent text-muted hover:text-foreground",
            ]}
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
      <ThemeToggle />
    </div>

    <button
      id="mobile-menu-btn"
      class="flex h-10 w-10 items-center justify-center text-muted lg:hidden"
      aria-label="Open navigation"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg
        class="w-5 h-5"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-border bg-background lg:hidden">
    <div class="mx-auto flex max-w-site flex-col px-5 py-5 sm:px-8">
      {
        site.navigation.map((item) => (
          <a
            href={item.href}
            class:list={[
              "border-b border-border py-4 font-mono text-sm",
              isActive(item.href) ? "text-primary" : "text-muted",
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <div class="pt-4">
        <ThemeToggle />
      </div>
    </div>
  </div>
</header>

<script>
  const menuButton = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");

  menuButton?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden", isOpen);
    menuButton.setAttribute("aria-expanded", String(!isOpen));
    menuButton.setAttribute(
      "aria-label",
      isOpen ? "Open navigation" : "Close navigation",
    );
  });
</script>
