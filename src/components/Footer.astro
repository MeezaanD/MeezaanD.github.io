---
import { site } from "../data/site";
---

<footer class="border-t border-border py-10">
  <div class="mx-auto flex max-w-site flex-col gap-7 px-5 sm:px-8 md:flex-row md:items-end md:justify-between">
    <div>
      <p class="font-display text-lg">A small place for work and thought.</p>
      <a
        class="mt-3 inline-flex items-center gap-2 font-mono text-sm text-primary underline decoration-transparent underline-offset-[0.28em] transition-colors hover:decoration-current"
        href={`mailto:${site.email}`}
      >
        {site.email}
      </a>
    </div>
    <div class="flex flex-col gap-3 md:items-end">
      <nav class="flex flex-wrap gap-x-5 gap-y-2" aria-label="Footer">
        {[...site.social, ...site.references].map((item) => (
          <a
            href={item.href}
            class="font-mono text-xs text-muted transition-colors hover:text-foreground"
            target={item.href.startsWith("http") || item.href.endsWith(".pdf") ? "_blank" : undefined}
            rel={item.href.startsWith("http") || item.href.endsWith(".pdf") ? "noopener noreferrer" : undefined}
          >
            {item.label}
          </a>
        ))}
      </nav>
      <p class="font-mono text-[0.7rem] text-subtle">
        &copy; {new Date().getFullYear()} {site.name}
      </p>
    </div>
  </div>
</footer>
