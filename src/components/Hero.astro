---
import { getEntry } from "astro:content";

const hero = await getEntry("hero", "index");
const { name, headline, description, quote, cta } = hero!.data;
---

<section class="section-padding pt-40">
  <div class="container-site">
    <p class="text-base tracking-[0.3em] uppercase mb-4 text-primary font-bold">
      {name}
    </p>
    <h1
      class="font-display text-3xl md:text-4xl lg:text-5xl mb-6 leading-tight max-w-3xl"
    >
      {headline}
    </h1>
    <p class="text-foreground/50 text-base max-w-3xl mb-6 leading-relaxed">
      {description}
    </p>
    {
      quote && (
        <blockquote class="border-l-2 border-primary/50 pl-4 mb-10 max-w-2xl">
          <p class="text-foreground/40 text-sm italic leading-relaxed">
            "{quote}"
          </p>
        </blockquote>
      )
    }
    <p class="text-foreground/40 text-sm md:text-base italic">{cta.text}</p>
  </div>
</section>
