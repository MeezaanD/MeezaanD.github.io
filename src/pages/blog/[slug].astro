---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content } = await render(post);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
  }).format(date);
---

<Layout title={`${post.data.title} | Meezaan Davids`} description={post.data.description}>
  <article class="mx-auto max-w-[54rem] px-5 pb-24 pt-36 sm:px-8 md:pb-32 md:pt-40">
    <header class="mb-14 max-w-[50rem]">
      <a
        class="inline-flex items-center gap-[0.45rem] font-mono text-[0.82rem] text-muted transition-colors duration-[180ms] hover:text-primary"
        href="/blog"
      >
        <span aria-hidden="true">←</span> All writing
      </a>

      <div class="mt-10 flex flex-wrap gap-x-5 gap-y-2 font-mono text-xs uppercase tracking-[0.06em] text-subtle md:mt-12">
        <time datetime={post.data.pubDate.toISOString()}>
          {formatDate(post.data.pubDate)}
        </time>
        {
          post.data.updatedDate && (
            <span>
              Updated{" "}
              <time datetime={post.data.updatedDate.toISOString()}>
                {formatDate(post.data.updatedDate)}
              </time>
            </span>
          )
        }
      </div>

      <h1 class="mb-6 mt-5 max-w-3xl text-[clamp(2.35rem,6vw,4.25rem)] leading-[1.04] tracking-[-0.04em]">
        {post.data.title}
      </h1>
      <p class="mt-6 max-w-[45rem] text-[clamp(1.05rem,2vw,1.25rem)] leading-[1.75] text-muted">
        {post.data.description}
      </p>

      <ul class="mt-6 flex flex-wrap gap-2" aria-label="Tags">
        {post.data.tags.map((tag) => (
          <li class="rounded-full border border-border px-[0.65rem] py-[0.35rem] font-mono text-[0.72rem] text-muted">
            {tag}
          </li>
        ))}
      </ul>
    </header>

    {
      post.data.heroImage && (
        <img
          class="mb-16 max-h-[34rem] w-full rounded-lg object-cover"
          src={post.data.heroImage}
          alt=""
          loading="eager"
        />
      )
    }

    <div
      class="mx-auto
        [&_p]:my-6 [&_p]:text-[clamp(1rem,2vw,1.12rem)] [&_p]:leading-[1.9] [&_p]:text-muted
        [&_li]:my-[0.6rem] [&_li]:pl-[0.35rem] [&_li]:text-[clamp(1rem,2vw,1.12rem)] [&_li]:leading-[1.9] [&_li]:text-muted
        [&_h2]:mb-4 [&_h2]:mt-14 [&_h2]:text-[clamp(1.75rem,4vw,2.4rem)] [&_h2]:leading-[1.2] [&_h2]:tracking-[-0.02em]
        [&_h3]:mb-3 [&_h3]:mt-11 [&_h3]:text-[clamp(1.35rem,3vw,1.75rem)] [&_h3]:leading-[1.3]
        [&_ul]:my-6 [&_ul]:list-disc [&_ul]:pl-6
        [&_ol]:my-6 [&_ol]:list-decimal [&_ol]:pl-6
        [&_a]:break-words [&_a]:text-primary [&_a]:underline [&_a]:decoration-1 [&_a]:underline-offset-[0.2em]
        [&_blockquote]:my-10 [&_blockquote]:border-l-[3px] [&_blockquote]:border-primary [&_blockquote]:pl-6 [&_blockquote]:font-display [&_blockquote]:text-xl [&_blockquote]:italic
        [&_code]:rounded [&_code]:bg-surface [&_code]:px-[0.35rem] [&_code]:py-[0.15rem] [&_code]:font-mono [&_code]:text-[0.9em]
        [&_pre]:my-8 [&_pre]:overflow-x-auto [&_pre]:rounded-lg [&_pre]:border [&_pre]:border-border [&_pre]:bg-surface [&_pre]:p-5
        [&_pre_code]:bg-transparent [&_pre_code]:p-0
        [&_hr]:my-14 [&_hr]:border-0 [&_hr]:border-t [&_hr]:border-border
        [&_img]:my-10 [&_img]:w-full [&_img]:rounded-lg"
    >
      <Content />
    </div>

    <footer class="mx-auto mt-[4.5rem] max-w-[46rem] border-t border-border pt-8">
      <a
        class="inline-flex items-center gap-[0.45rem] font-mono text-[0.82rem] text-muted transition-colors duration-[180ms] hover:text-primary"
        href="/blog"
      >
        <span aria-hidden="true">←</span> Back to all writing
      </a>
    </footer>
  </article>
</Layout>
