---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
  }).format(date);
---

<Layout
  title="Developer Digest | Meezaan Davids"
  description="Daily readings on AI-assisted development, frontend engineering, architecture, security, and developer tools."
>
  <section class="container-site blog-index">
    <header class="blog-header">
      <p class="eyebrow">Developer intelligence</p>
      <h1>A daily digest for thoughtful builders.</h1>
      <p class="intro">
        Notes on AI-assisted development, frontend engineering, architecture,
        security, and the tools changing how software gets made.
      </p>
    </header>

    {
      posts.length > 0 ? (
        <div class="post-list">
          {posts.map((post) => (
            <article class="post-card">
              <p class="post-date">
                <time datetime={post.data.pubDate.toISOString()}>
                  {formatDate(post.data.pubDate)}
                </time>
              </p>
              <h2>
                <a href={`/blog/${post.id}/`}>{post.data.title}</a>
              </h2>
              <p class="post-description">{post.data.description}</p>
              <ul class="tag-list" aria-label="Tags">
                {post.data.tags.map((tag) => (
                  <li>{tag}</li>
                ))}
              </ul>
              <a class="read-link" href={`/blog/${post.id}/`}>
                Read digest <span aria-hidden="true">→</span>
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <h2>The first digest is on its way.</h2>
          <p>New developer intelligence will appear here when it is published.</p>
        </div>
      )
    }
  </section>
</Layout>

<style>
  .blog-index {
    min-height: 80vh;
    padding-top: 10rem;
    padding-bottom: 6rem;
  }

  .blog-header {
    max-width: 48rem;
    margin-bottom: 5rem;
  }

  .eyebrow {
    margin-bottom: 1rem;
    color: var(--color-primary);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 44rem;
    font-size: clamp(2.5rem, 7vw, 4.75rem);
    line-height: 1.04;
    letter-spacing: -0.035em;
  }

  .intro {
    max-width: 40rem;
    margin-top: 1.5rem;
    color: color-mix(in srgb, var(--color-foreground) 58%, transparent);
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.8;
  }

  .post-list {
    border-top: 1px solid
      color-mix(in srgb, var(--color-foreground) 10%, transparent);
  }

  .post-card {
    display: grid;
    grid-template-columns: minmax(8rem, 0.3fr) minmax(0, 1fr);
    gap: 0.75rem 3rem;
    padding: 2.75rem 0;
    border-bottom: 1px solid
      color-mix(in srgb, var(--color-foreground) 10%, transparent);
  }

  .post-date {
    grid-row: 1 / span 4;
    padding-top: 0.4rem;
    color: color-mix(in srgb, var(--color-foreground) 42%, transparent);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h2 {
    max-width: 48rem;
    font-size: clamp(1.65rem, 4vw, 2.4rem);
    line-height: 1.18;
  }

  h2 a {
    transition: color 180ms ease;
  }

  h2 a:hover {
    color: var(--color-primary);
  }

  .post-description {
    max-width: 44rem;
    color: color-mix(in srgb, var(--color-foreground) 55%, transparent);
    line-height: 1.75;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.35rem;
  }

  .tag-list li {
    padding: 0.35rem 0.65rem;
    border: 1px solid
      color-mix(in srgb, var(--color-foreground) 12%, transparent);
    border-radius: 999px;
    color: color-mix(in srgb, var(--color-foreground) 55%, transparent);
    font-size: 0.72rem;
  }

  .read-link {
    width: fit-content;
    margin-top: 0.5rem;
    color: var(--color-primary);
    font-size: 0.85rem;
    font-weight: 500;
  }

  .read-link span {
    display: inline-block;
    transition: transform 180ms ease;
  }

  .read-link:hover span {
    transform: translateX(0.25rem);
  }

  .empty-state {
    padding: 3rem;
    border: 1px solid
      color-mix(in srgb, var(--color-foreground) 10%, transparent);
    border-radius: 0.5rem;
    text-align: center;
  }

  .empty-state h2 {
    margin: 0 auto 0.75rem;
  }

  .empty-state p {
    color: color-mix(in srgb, var(--color-foreground) 50%, transparent);
  }

  @media (max-width: 640px) {
    .blog-index {
      padding-top: 8rem;
      padding-bottom: 4rem;
    }

    .blog-header {
      margin-bottom: 3.5rem;
    }

    .post-card {
      display: block;
      padding: 2.25rem 0;
    }

    .post-date {
      margin-bottom: 0.9rem;
      padding-top: 0;
    }

    .post-description,
    .tag-list,
    .read-link {
      margin-top: 1rem;
    }
  }
</style>
