---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
  }).format(date);
---

<Layout
  title="Writing | Meezaan Davids"
  description="Notes on software, systems thinking, architecture, security, and the changing practice of development."
>
  <section class="mx-auto min-h-[80vh] max-w-site px-5 pb-24 pt-36 sm:px-8 md:pb-32 md:pt-44">
    <header class="mb-14 max-w-3xl md:mb-20">
      <p class="font-mono text-[0.72rem] font-medium uppercase tracking-[0.15em] text-subtle">
        Writing
      </p>
      <h1 class="mb-6 mt-4 max-w-3xl font-display text-[clamp(3rem,7vw,5.8rem)] leading-none tracking-[-0.05em]">
        Notes on software and the judgment around it.
      </h1>
      <p class="mt-6 max-w-[40rem] text-[clamp(1rem,2vw,1.2rem)] leading-[1.8] text-muted">
        Essays and field notes on engineering, architecture, security,
        AI-assisted development, and the systems behind the interface.
      </p>
    </header>

    {
      posts.length > 0 ? (
        <div class="border-t border-border">
          {posts.map((post) => (
            <article class="grid grid-cols-[minmax(8rem,0.3fr)_minmax(0,1fr)] gap-x-12 gap-y-3 border-b border-border py-11 max-[640px]:block max-[640px]:py-9">
              <p class="row-span-4 pt-[0.4rem] font-mono text-[0.72rem] font-medium uppercase tracking-[0.15em] text-subtle max-[640px]:mb-[0.9rem] max-[640px]:pt-0">
                <time datetime={post.data.pubDate.toISOString()}>
                  {formatDate(post.data.pubDate)}
                </time>
              </p>
              <h2 class="max-w-3xl text-[clamp(1.65rem,4vw,2.4rem)] leading-[1.18]">
                <a
                  class="transition-colors duration-[180ms] hover:text-primary"
                  href={`/blog/${post.id}/`}
                >
                  {post.data.title}
                </a>
              </h2>
              <p class="max-w-[44rem] leading-[1.75] text-muted max-[640px]:mt-4">
                {post.data.description}
              </p>
              <ul class="mt-[0.35rem] flex flex-wrap gap-2 max-[640px]:mt-4" aria-label="Tags">
                {post.data.tags.map((tag) => (
                  <li class="rounded-full border border-border px-[0.65rem] py-[0.35rem] font-mono text-[0.72rem] text-muted">
                    {tag}
                  </li>
                ))}
              </ul>
              <a
                class="group mt-2 inline-flex w-fit items-center gap-2 font-mono text-[0.8rem] text-primary underline decoration-transparent underline-offset-[0.28em] transition-[text-decoration-color] duration-[160ms] hover:decoration-current max-[640px]:mt-4"
                href={`/blog/${post.id}/`}
              >
                Read note
                <span class="inline-block transition-transform duration-[180ms] group-hover:translate-x-1" aria-hidden="true">
                  →
                </span>
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div class="border border-border p-12 text-center">
          <h2 class="mx-auto mb-3 max-w-3xl text-[clamp(1.65rem,4vw,2.4rem)] leading-[1.18]">
            The first digest is on its way.
          </h2>
          <p class="text-muted">
            New developer intelligence will appear here when it is published.
          </p>
        </div>
      )
    }
  </section>
</Layout>
