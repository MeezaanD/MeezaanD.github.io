---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Page not found | Meezaan Davids"
  description="The requested page could not be found."
>
  <div class="mx-auto flex min-h-[82vh] max-w-site flex-col justify-center px-5 pb-24 pt-32 sm:px-8">
    <p class="font-mono text-[0.72rem] font-medium uppercase tracking-[0.15em] text-subtle">
      Error 404
    </p>
    <h1 class="mt-4 max-w-3xl text-[clamp(3rem,8vw,6rem)] leading-[0.98] tracking-[-0.05em]">
      This page is not part of the map.
    </h1>
    <p class="my-8 max-w-xl leading-[1.8] text-muted">
      The address may have changed, or the thing you were looking for may no
      longer live here.
    </p>
    <a
      class="inline-flex items-center gap-2 self-start font-mono text-sm text-primary underline decoration-transparent underline-offset-[0.28em] transition-[text-decoration-color] duration-[160ms] hover:decoration-current"
      href="/"
    >
      Return home <span aria-hidden="true">→</span>
    </a>
  </div>
</Layout>
