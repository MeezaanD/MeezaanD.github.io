---
import { getEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { site } from "../data/site";

const now = await getEntry("now", "index");

const nowItems = now
  ? [now.data.work, now.data.learning, now.data.curiosity]
  : [];
---

<Layout title="Meezaan Davids | Software, systems, and learning">
  <section class="mx-auto max-w-site px-5 pb-32 pt-44 sm:px-8 max-[700px]:pb-[5.5rem] max-[700px]:pt-[8.5rem]">
    <div class="grid gap-8 md:grid-cols-[10rem_minmax(0,1fr)] md:gap-12">
      <p class="pt-3 font-mono text-[0.72rem] font-medium uppercase tracking-[0.15em] text-subtle">
        {site.name}
      </p>
      <div class="max-w-[54rem]">
        <h1 class="max-w-[52rem] text-[clamp(3rem,7.5vw,6.4rem)] leading-[0.98] tracking-[-0.055em] max-[700px]:text-[clamp(2.8rem,15vw,4.5rem)]">
          Building software with judgment and intention.
        </h1>
        <p class="my-9 max-w-[44rem] text-[clamp(1.05rem,2vw,1.25rem)] leading-[1.8] text-muted">
          I am a software developer interested in the whole system: the
          interface, the architecture beneath it, and the decisions that make
          technology useful to people.
        </p>
        <a
          class="inline-flex items-center gap-2 font-mono text-sm text-primary underline decoration-transparent underline-offset-[0.28em] transition-[text-decoration-color] duration-[160ms] hover:decoration-current"
          href="/now"
        >
          What I am focused on now <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <section
    class="mx-auto max-w-site border-t border-border px-5 py-[5.5rem] sm:px-8 max-[700px]:py-16"
    aria-labelledby="now-heading"
  >
    <div class="mb-11 flex items-end justify-between gap-8 max-[700px]:mb-8 max-[700px]:block">
      <div>
        <p class="font-mono text-[0.72rem] font-medium uppercase tracking-[0.15em] text-subtle">
          Current state
        </p>
        <h2
          class="mt-[0.45rem] text-[clamp(2.1rem,5vw,3.7rem)] leading-[1.08] tracking-[-0.035em]"
          id="now-heading"
        >
          Now
        </h2>
      </div>
      <a
        class="inline-flex items-center gap-2 font-mono text-sm text-primary underline decoration-transparent underline-offset-[0.28em] transition-[text-decoration-color] duration-[160ms] hover:decoration-current max-[700px]:mt-4"
        href="/now"
      >
        The full update <span aria-hidden="true">→</span>
      </a>
    </div>
    <div class="border-t border-border">
      {
        nowItems.map((item) => (
          <article class="grid gap-4 border-b border-border py-7 md:grid-cols-[10rem_minmax(0,1fr)] md:gap-10 md:py-9">
            <h3 class="font-mono text-sm font-medium text-foreground">
              {item.title}
            </h3>
            <p class="max-w-3xl leading-7 text-muted">{item.text}</p>
          </article>
        ))
      }
    </div>
  </section>



  <section
    class="mx-auto max-w-site border-t border-border px-5 py-[5.5rem] sm:px-8 max-[700px]:py-16"
    aria-labelledby="elsewhere-heading"
  >
    <div class="mb-11 flex items-end justify-between gap-8 max-[700px]:mb-8 max-[700px]:block">
      <div>
        <p class="font-mono text-[0.72rem] font-medium uppercase tracking-[0.15em] text-subtle">
          Around the web
        </p>
        <h2
          class="mt-[0.45rem] text-[clamp(2.1rem,5vw,3.7rem)] leading-[1.08] tracking-[-0.035em]"
          id="elsewhere-heading"
        >
          Elsewhere
        </h2>
      </div>
    </div>
    <div class="grid grid-cols-2 border-t border-border max-[700px]:grid-cols-1">
      {
        [...site.products, ...site.social.map((item) => ({ ...item, description: "Find me and follow the work." }))].map(
          (item, index) => (
            <a
              class:list={[
                "group flex justify-between gap-6 border-b border-border py-7 max-[700px]:px-0 max-[700px]:border-l-0",
                index % 2 === 0 ? "pr-8" : "border-l border-border pl-8",
              ]}
              href={item.href}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span>
                <strong class="block font-mono text-[0.9rem] font-medium transition-colors group-hover:text-primary">
                  {item.label}
                </strong>
                <small class="mt-[0.45rem] block text-[0.85rem] leading-[1.5] text-muted">
                  {item.description}
                </small>
              </span>
              <span class="text-subtle transition-colors group-hover:text-primary" aria-hidden="true">
                ↗
              </span>
            </a>
          ),
        )
      }
    </div>
  </section>

  <section
    class="mx-auto max-w-site border-t border-border px-5 pb-32 pt-28 sm:px-8"
    id="contact"
    aria-labelledby="contact-heading"
  >
    <p class="font-mono text-[0.72rem] font-medium uppercase tracking-[0.15em] text-subtle">
      Contact
    </p>
    <h2
      class="mt-[0.45rem] text-[clamp(2.1rem,5vw,3.7rem)] leading-[1.08] tracking-[-0.035em]"
      id="contact-heading"
    >
      Say hello.
    </h2>
    <p class="mb-7 mt-5 max-w-[34rem] leading-[1.75] text-muted">
      For thoughtful conversations about software, systems, and the work around
      them.
    </p>
    <a
      class="inline-flex items-center gap-2 font-mono text-sm text-primary underline decoration-transparent underline-offset-[0.28em] transition-[text-decoration-color] duration-[160ms] hover:decoration-current"
      href={`mailto:${site.email}`}
    >
      {site.email} <span aria-hidden="true">→</span>
    </a>
  </section>
</Layout>
